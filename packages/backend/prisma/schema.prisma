// Esquema Prisma — Fase 3: materializa el modelo de datos derivado del dominio.
// Ver Docs/modelo-datos.md. Los vocabularios cerrados se validan en el dominio
// (string unions ASCII), por eso aquí se guardan como String/String[] y no como
// enums de Prisma: evita acoplar la persistencia al ORM y simplifica el mapeo.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
  // Fuerza extensión `.js` en los imports del cliente generado. Sin esto, el generador
  // puede emitir imports con `.ts` (no determinista) que `tsc` NO reescribe → el
  // `dist/generated/prisma/client.js` importaría `./enums.ts` (inexistente en runtime) y
  // `node dist/index.js` crashea (ERR_MODULE_NOT_FOUND). Con `.js` resuelve en runtime y,
  // bajo tsc/vitest (NodeNext), `.js` mapea al `.ts` fuente.
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

/// Adulto responsable. Presta el consentimiento; todo niño cuelga de él.
model Guardian {
  id                 String         @id @default(uuid())
  nombre             String
  apellidos          String
  email              String         @unique
  parentesco         String
  telefono           String?
  passwordHash       String
  consentimientoDado Boolean
  consentimientoEn   DateTime
  consentimientoVer  String
  /// Titularidad del email verificada por OTP (US-93). Las cuentas creadas sin SMTP
  /// configurado quedan verificadas al alta; con SMTP, hasta validar el código.
  emailVerificado    Boolean            @default(false)
  creadoEn           DateTime           @default(now())
  perfiles           ChildProfile[]
  auditLogs          AuditLog[]
  emailVerification  EmailVerification?

  @@map("guardians")
}

/// Verificación de titularidad del email por OTP (US-93). Estado transitorio de
/// seguridad, 1-1 con el guardián; se borra en cascada con él. El código se guarda
/// **hasheado** (bcrypt), nunca en claro. `intentos` limita la fuerza bruta y
/// `expiraEn` la caducidad; `verificadoEn` marca el consumo.
model EmailVerification {
  id           String    @id @default(uuid())
  guardianId   String    @unique
  guardian     Guardian  @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  codigoHash   String
  expiraEn     DateTime
  intentos     Int       @default(0)
  verificadoEn DateTime?
  creadoEn     DateTime  @default(now())

  @@map("email_verifications")
}

/// Perfil de un niño. Borrado en cascada al borrar su Guardian (GDPR).
model ChildProfile {
  id         String             @id @default(uuid())
  guardianId String
  guardian   Guardian           @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  nombre     String
  edad       Int
  idioma     String
  avatar     String
  intereses  String[]
  creadoEn   DateTime           @default(now())
  stories      Story[]
  activities   Activity[]
  events       InteractionEvent[]
  achievements Achievement[]

  @@index([guardianId])
  @@map("child_profiles")
}

/// Cuento generado para un perfil. Se elimina en cascada con el perfil.
model Story {
  id        String       @id @default(uuid())
  profileId String
  profile   ChildProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tema      String
  estilo    String
  ensenanza String?
  titulo    String
  cuerpo    String
  idioma    String
  estado    String       @default("nuevo")
  proveedor String       @default("mock")
  portada   String?
  prompt    String?
  continuacionDe String?
  favorito  Boolean      @default(false)
  creadoEn  DateTime     @default(now())
  narration StoryNarration?

  @@index([profileId])
  @@map("stories")
}

/// Narración (audio MP3) de un cuento. Caché 1-1: se sintetiza una vez con
/// ElevenLabs y se reusa. Se borra en cascada con el cuento (y con el perfil).
model StoryNarration {
  id       String   @id @default(uuid())
  storyId  String   @unique
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  mp3      Bytes
  voiceId  String
  idioma   String
  creadoEn DateTime @default(now())

  @@map("story_narrations")
}

/// Actividad generada por IA para un perfil (progreso como estado, sin entidad aparte).
model Activity {
  id           String       @id @default(uuid())
  profileId    String
  profile      ChildProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  categoria    String
  titulo       String
  descripcion  String
  instrucciones String?
  duracionMin  Int?
  nivel        Int?
  proveedor    String       @default("mock")
  imagen       String?
  prompt       String?
  completadaEn DateTime?
  valoracion   Int?
  favorito     Boolean      @default(false)
  creadoEn     DateTime     @default(now())

  @@index([profileId])
  @@map("activities")
}

/// Tracking de primera parte. Sin PII en payload; niño referido por profileId.
model InteractionEvent {
  id        String       @id @default(uuid())
  profileId String
  profile   ChildProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tipo      String
  payload   Json?
  creadoEn  DateTime     @default(now())

  @@index([profileId])
  @@map("interaction_events")
}

/// Trazabilidad de acciones sensibles del adulto (incl. consentimiento).
model AuditLog {
  id         String    @id @default(uuid())
  guardianId String?
  guardian   Guardian? @relation(fields: [guardianId], references: [id], onDelete: SetNull)
  accion     String
  entidad    String
  entidadId  String
  metadatos  Json?
  creadoEn   DateTime  @default(now())

  @@index([guardianId])
  @@map("audit_logs")
}

/// Logro/recompensa desbloqueado por un perfil (US-68). Solo el hecho (clave +
/// fecha); el progreso se calcula en caliente. Unicidad por perfil+clave (idempotente).
/// Se elimina en cascada con el perfil (y con el guardián).
model Achievement {
  id             String       @id @default(uuid())
  profileId      String
  profile        ChildProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  clave          String
  desbloqueadoEn DateTime     @default(now())

  @@unique([profileId, clave])
  @@index([profileId])
  @@map("achievements")
}

/// Configuración clave-valor ajustable en caliente (prompts, modelo, parámetros).
/// Secretos NO van aquí (siguen en variables de entorno).
model AppSetting {
  id            String   @id @default(uuid())
  key           String   @unique
  value         String
  descripcion   String?
  /// Versión aplicada de la clave (US-70). Gobierna el sync versionado desde
  /// `prisma/app-settings.json`: el sync solo reescribe cuando la versión del JSON
  /// es mayor, para no pisar cambios hechos en caliente (p. ej. `ai.cloud`).
  version       Int      @default(0)
  actualizadoEn DateTime @updatedAt

  @@map("app_settings")
}
