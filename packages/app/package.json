{
  "name": "@magyblob/app",
  "version": "1.4.0",
  "private": true,
  "description": "App móvil (Expo + Zustand). Slice vertical del HITO 1 (Fase 4).",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e:install": "playwright install chromium webkit",
    "test:e2e": "EXPO_PUBLIC_API_URL=http://127.0.0.1:4173 EXPO_PUBLIC_SENTRY_DSN= expo export --platform web --clear && playwright test"
  },
  "dependencies": {
    "@expo-google-fonts/quicksand": "^0.4.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.17.2",
    "@react-navigation/native": "^7.3.0",
    "@react-navigation/native-stack": "^7.17.2",
    "@sentry/react-native": "^8.15.1",
    "expo": "~56.0.11",
    "expo-audio": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.6",
    "expo-haptics": "~56.0.3",
    "expo-speech": "~56.0.3",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "i18next": "^26.3.2",
    "lucide-react-native": "^1.20.0",
    "react": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "~19.2.2",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^29.1.1",
    "react-dom": "19.2.3",
    "react-native-web": "^0.21.2",
    "typescript": "~6.0.3",
    "vitest": "^2.1.8"
  }
}
