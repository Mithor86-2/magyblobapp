{
  "name": "@magyblob/app",
  "version": "1.16.2",
  "private": true,
  "description": "App móvil (Expo + Zustand). Slice vertical del HITO 1 (Fase 4).",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e:install": "playwright install chromium",
    "test:e2e": "EXPO_PUBLIC_API_URL=http://127.0.0.1:4173 EXPO_PUBLIC_SENTRY_DSN= expo export --platform web --clear && playwright test"
  },
  "dependencies": {
    "@expo-google-fonts/quicksand": "^0.4.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "@sentry/react-native": "^8.18.0",
    "expo": "~56.0.16",
    "expo-application": "~56.0.3",
    "expo-asset": "~56.0.20",
    "expo-audio": "~56.0.12",
    "expo-constants": "~56.0.21",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-navigation-bar": "~56.0.3",
    "expo-speech": "~56.0.3",
    "expo-splash-screen": "~56.0.13",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "i18next": "^26.3.6",
    "lucide-react-native": "^1.24.0",
    "react": "19.2.7",
    "react-i18next": "^17.0.10",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.26.1",
    "react-native-svg": "15.15.5",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "~19.2.2",
    "@vitest/coverage-v8": "^3.2.7",
    "babel-preset-expo": "~56.0.17",
    "jsdom": "^29.1.1",
    "react-dom": "19.2.7",
    "react-native-web": "^0.21.2",
    "typescript": "~6.0.3",
    "vitest": "^3.2.7"
  },
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native"
      ]
    }
  }
}
