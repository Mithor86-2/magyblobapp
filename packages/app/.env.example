# Variables de entorno de la app Expo. Copiar a .env (las EXPO_PUBLIC_* se
# inlinean en el bundle, así que NUNCA pongas secretos aquí).

# URL base del backend.
# - Simulador iOS / Expo web: http://localhost:3000 sirve.
# - Dispositivo físico (Expo Go): usa la IP LAN del ordenador, p. ej.
#   http://192.168.1.42:3000 (el móvil y el ordenador en la misma red).
EXPO_PUBLIC_API_URL=http://localhost:3000
