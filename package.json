{
  "name": "magyblobapp",
  "version": "0.32.0",
  "private": true,
  "type": "module",
  "description": "App infantil bilingüe que crea perfiles y genera cuentos con IA local (TFM Máster)",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "pnpm --filter @magyblob/backend dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "coverage": "pnpm -r --if-present test:coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test",
    "ollama:setup": "bash scripts/setup-ollama.sh",
    "ai:smoke": "pnpm --filter @magyblob/backend exec tsx scripts/smoke-ollama.ts",
    "ai:smoke:cloud": "pnpm --filter @magyblob/backend exec tsx scripts/smoke-cloud.ts",
    "up": "docker compose up",
    "up:build": "docker compose up --build",
    "up:mock": "bash scripts/up-mock.sh",
    "up:local": "bash scripts/up-local.sh",
    "down": "docker compose down",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/backend/**/*.ts": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "packages/app/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
