echo "🚀 pre-push: gate completo (pnpm check + coverage)…"
pnpm check || {
  echo "❌ Gate en rojo. Arregla typecheck/lint/format/test antes de hacer push."
  exit 1
}
pnpm coverage || {
  echo "❌ Cobertura por debajo del umbral (US-35). Añade tests antes de hacer push."
  exit 1
}
echo "✅ Gate + cobertura verdes. Push permitido."
