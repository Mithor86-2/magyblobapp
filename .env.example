# ─────────────────────────────────────────────────────────────
# magyblobapp — variables de entorno (copiar a .env)
# ─────────────────────────────────────────────────────────────

# --- Backend ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Sesión / JWT (US-45) ---
# Secreto de firma de los JWT de sesión del adulto (access + refresh). En
# producción DEBE fijarse a un valor largo y aleatorio; si se deja vacío se usa
# un secreto de desarrollo inseguro (solo para arranque reproducible local).
JWT_SECRET=
# Vida de los tokens (formato de `ms`/`fast-jwt`: 15m, 1h, 7d, ...).
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- PostgreSQL ---
POSTGRES_USER=magyblob
POSTGRES_PASSWORD=magyblob
POSTGRES_DB=magyblob
# En local (fuera de Docker) usa localhost; dentro de docker-compose se
# sobreescribe automáticamente al host del servicio "postgres".
DATABASE_URL=postgresql://magyblob:magyblob@localhost:5432/magyblob?schema=public

# --- Capa de IA ---
# Modo base del proveedor: mock | local
AI_PROVIDER=mock

# Modo local (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:2b
# Timeout del proveedor de IA antes de caer a mock (ms)
AI_TIMEOUT_MS=60000

# --- Modo cloud (ON por defecto) ---
# El modo cloud viene ACTIVO por defecto (AppSetting `ai.cloud`, target `groq`),
# cargado al arrancar por una migración; es conmutable en caliente desde la BD.
# La activación NO se hace por env: aquí solo va el SECRETO, la API key del target.
# Pon la key del target activo (groq por defecto). SIN key, el backend cae al modo
# base (mock/local) automáticamente. Targets: groq | gemini | openrouter | cerebras.
GROQ_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# CEREBRAS_API_KEY=

# --- Narración de cuentos (ElevenLabs, US-22) ---
# Secreto: API key de ElevenLabs (xi-api-key). Sin ella, la app narra con la
# voz nativa del dispositivo (fallback). NOTA: la narración envía el texto del
# cuento a un tercero en la nube (ver Docs/cumplimiento-menores.md).
ELEVENT_LABS_API=
# Modelo de síntesis (multilingüe ES/EN).
ELEVENLABS_MODEL=eleven_multilingual_v2
# Voz por idioma (voice_id de ElevenLabs). Por defecto se usan voces premade.
ELEVENLABS_VOICE_ID_ES=
ELEVENLABS_VOICE_ID_EN=
# Timeout de la petición a ElevenLabs (ms).
ELEVENLABS_TIMEOUT_MS=30000
