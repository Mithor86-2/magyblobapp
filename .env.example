# ─────────────────────────────────────────────────────────────
# magyblobapp — variables de entorno (copiar a .env)
# ─────────────────────────────────────────────────────────────

# --- Backend ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- PostgreSQL ---
POSTGRES_USER=magyblob
POSTGRES_PASSWORD=magyblob
POSTGRES_DB=magyblob
# En local (fuera de Docker) usa localhost; dentro de docker-compose se
# sobreescribe automáticamente al host del servicio "postgres".
DATABASE_URL=postgresql://magyblob:magyblob@localhost:5432/magyblob?schema=public

# --- Capa de IA ---
# Modo base del proveedor: mock | local
AI_PROVIDER=mock

# Modo local (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:2b
# Timeout del proveedor de IA antes de caer a mock (ms)
AI_TIMEOUT_MS=60000

# --- Modo cloud (opt-in, OFF por defecto) ---
# El modo cloud NO se activa por env: se activa desde la BD, en la clave
# AppSetting `ai.cloud` = {"activo":true,"target":"groq","model":"..."} (ver seed).
# Aquí solo van los SECRETOS: la API key del proveedor (target) que vayas a usar.
# Solo necesitas la del target activo. Targets: groq | gemini | openrouter | cerebras.
# GROQ_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# CEREBRAS_API_KEY=
