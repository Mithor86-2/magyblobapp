# ─────────────────────────────────────────────────────────────
# magyblobapp — variables de entorno (copiar a .env)
# ─────────────────────────────────────────────────────────────

# --- Backend ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- PostgreSQL ---
POSTGRES_USER=magyblob
POSTGRES_PASSWORD=magyblob
POSTGRES_DB=magyblob
# En local (fuera de Docker) usa localhost; dentro de docker-compose se
# sobreescribe automáticamente al host del servicio "postgres".
DATABASE_URL=postgresql://magyblob:magyblob@localhost:5432/magyblob?schema=public

# --- Capa de IA ---
# Modo del proveedor: mock | local
AI_PROVIDER=mock

# Modo local (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:2b
# Timeout del proveedor de IA antes de caer a mock (ms)
AI_TIMEOUT_MS=60000
